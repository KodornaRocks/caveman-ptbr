{
  "name": "caveman",
  "description": "Modo de comunicação ultra-comprimido. Corta ~75% dos tokens mantendo precisão técnica completa falando como caveman.",
  "author": {
    "name": "Julius Brussee",
    "url": "https://github.com/JuliusBrussee"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/caveman-activate.js",
            "timeout": 5,
            "statusMessage": "Carregando modo caveman..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/caveman-mode-tracker.js",
            "timeout": 5,
            "statusMessage": "Rastreando modo caveman..."
          }
        ]
      }
    ]
  }
}
